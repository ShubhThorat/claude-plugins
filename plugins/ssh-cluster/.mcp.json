{
  "mcpServers": {
    "ssh-cluster": {
      "command": "node",
      "args": ["${CLAUDE_PLUGIN_ROOT}/server/bundle.js"],
      "env": {
        "API_SERVER_URL": "",
        "API_SERVER_HOST": "",
        "API_SERVER_KEY": "",
        "API_KEY": "",
        "SSH_CLUSTER_PORT": "22",
        "SSH_CLUSTER_API_URL": "",
        "SSH_CLUSTER_API_KEY": "",
        "SSH_CLUSTER_USERNAME": "",
        "SSH_CLUSTER_STRICT_HOST_KEY": "true",
        "SSH_CLUSTER_MAX_OUTPUT_BYTES": "262144",
        "SSH_CLUSTER_DEFAULT_TIMEOUT_MS": "120000"
      }
    }
  }
}
